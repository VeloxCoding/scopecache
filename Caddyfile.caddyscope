# Minimal Caddyfile that mounts scopecache at the root of :8080.
#
# The scopecache block's three subdirectives mirror the standalone binary's
# env vars (SCOPECACHE_SCOPE_MAX_ITEMS, SCOPECACHE_MAX_STORE_MB,
# SCOPECACHE_MAX_ITEM_MB). Omit any of them to use the compile-time default.
#
# Mount paths other than root work too — the handler returns "next" for any
# path it does not recognise, so `handle /cache/*` with a `uri strip_prefix
# /cache` in front of the scopecache block also serves the API cleanly
# underneath a prefix.
{
    admin off
    log {
        output stdout
        format console
    }
}

:8080 {
    # Demo override: /render emits application/octet-stream (scopecache
    # deliberately does not sniff MIME types — see CLAUDE.md "fronting
    # proxy sets the real MIME type"). For this demo every /render
    # response is HTML, so rewrite the Content-Type here. In a real
    # deployment the operator decides per path/scope what the MIME type
    # should be.
    # `>` prefix = "late" header op — overschrijft de Content-Type die
    # scopecache zelf op /render zet (application/octet-stream).
    @render path /render
    header @render >Content-Type "text/html; charset=utf-8"

    scopecache {
        scope_max_items 100000
        max_store_mb    100
        max_item_mb     1
        # Enable /guarded by passing the HMAC key. Substituted from the
        # process env at config-load (see guardedflow.md §I). Empty/unset
        # would disable /guarded entirely (route returns 404).
        server_secret   {$SCOPECACHE_SERVER_SECRET}
        # Enable /inbox by listing operator-allowed shared write scope
        # names. Each line registers one. Empty list (no inbox_scope
        # directives) disables /inbox entirely.
        inbox_scope     _inbox
        inbox_scope     audit_log
    }
    # scopecache calls next() for any path it does not recognise; this
    # terminal handler then returns 404 instead of Caddy's default empty
    # 200. Drop or replace with your own handlers when mounting scopecache
    # alongside other services.
    respond 404
}
